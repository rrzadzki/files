' take2-bores
SA
CN, 90
IF %(25)=1 THEN GOTO UNIT_ERROR
&PWMaterial = 0.5
&PWZorigin = Part Surface

' Bore2
C7
&Tool = 3
C9
TR, 18000
C6
PAUSE 2
if %(22) = 1 then goto Start_Hit_1
Try_again_1:
&SW_State_8 = %(58)
